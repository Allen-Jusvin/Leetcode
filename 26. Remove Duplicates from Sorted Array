class Solution {
    public int removeDuplicates(int[] nums) {
        int[] arr=new int[nums.length];
        int count=0,x=1;
        arr[0]=nums[0];
        for(int i=1;i<nums.length;i++)
        {
            if(nums[i]!=arr[x-1])
            {
                arr[x]=nums[i];
                x++;
            }
        }
        for(int i=0;i<x;i++)
        {
            nums[i]=arr[i];
            count++;
        }
        return count;
    }
}
